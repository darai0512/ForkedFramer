# Sentry設定（ソースマップのアップロード用）
# Sentryのプロジェクト設定画面から取得してください

# Sentry認証トークン（Settings > Account > API > Auth Tokens で作成）
# 必要なスコープ: project:releases, org:read
SENTRY_AUTH_TOKEN=your-auth-token-here

# Sentry組織名（Settings > Organization Settings で確認）
SENTRY_ORG=your-org-name

# Sentryプロジェクト名（Settings > Projects で確認）
SENTRY_PROJECT=frameplanner

# リリース名（オプション、指定しない場合は日時が使用されます）
# SENTRY_RELEASE=1.0.0
